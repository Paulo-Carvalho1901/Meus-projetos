{
  "title": "API Observabilidade — OpenTelemetry",
  "uid": "otel-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total de Requisições",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(otel_api_requisicoes_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total de Erros",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(otel_api_erros_total)",
          "legendFormat": "Erros"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requisições por Endpoint (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (endpoint) (rate(otel_api_requisicoes_total[1m]))",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latência p95 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(otel_api_latencia_ms_milliseconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Logs da Aplicação",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "expr": "{job=\"api-observabilidade\"} | json"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "id": true
            },
            "renameByName": {
              "Time": "timestamp",
              "body": "mensagem",
              "level": "nivel",
              "service_name": "servico",
              "traceid": "trace_id"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Logs por Nível (1m)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "queryType": "range",
          "expr": "sum by (level) (count_over_time({job=\"api-observabilidade\"} | json [1m]))",
          "legendFormat": "{{level}}"
        }
      ]
    }
  ]
}
